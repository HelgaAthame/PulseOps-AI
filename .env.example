# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Secret key (backend-only, admin-доступ). Никогда не отдаётся на клиент.
SUPABASE_SECRET_KEY=your-secret-key

# Подключение к Postgres. Если прямое db.*.supabase.co не резолвится (IPv6-only),
# используйте Session Pooler: postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# --- Auth ---
# Базовый URL приложения (для OAuth/passkey redirect). В dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# hCaptcha (CAPTCHA). Site key — публичный (фронтенд).
# Secret key настраивается в Supabase Dashboard, не здесь.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# --- AI (Day 6: AI-аналитик «Explain what's happening») ---
# OpenRouter (OpenAI-совместимый). Бесплатные модели (:free) стоят $0.
# Ключ (бесплатный): https://openrouter.ai/keys. Роут /api/ai/analyze без него → 503.
OPENROUTER_API_KEY=
# Необязательно: конкретная модель. По умолчанию `openrouter/free` (авто-роутер
# бесплатных моделей). Список: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=
